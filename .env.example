# OpenAI Compatible API Configuration
# Copy this file to .env and fill in your credentials
# NEVER commit the .env file with real credentials

# Your OpenAI API key (can be any string for local servers)
OPENAI_API_KEY=

# Your base URL for OpenAI-compatible API server
OPENAI_BASE_URL=http://server.local:8000/v1

# Model name parameter (required for API calls)
MODEL_ID=qwen3.5
